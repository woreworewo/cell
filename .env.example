# =====================================================================
# Unwired Labs
# =====================================================================
# Token gratis 100 lookup/hari per akun. Boleh banyak token, dipisah
# koma. Script otomatis rotate kalau salah satu kena limit.
UWL_TOKEN=pk.aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa,pk.bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb

# =====================================================================
# Telegram bot (opsional - hanya kalau pakai bot.py)
# =====================================================================
# Token bot dari @BotFather
TG_BOT_TOKEN=

# Nama bot (muncul di /start, /help)
TG_BOT_NAME=LTE Cell Lookup

# Rate limit per user, dalam detik. Default 300 (= 5 menit).
TG_RATE_LIMIT_SEC=300

# Default MCC/MNC kalau user pakai /cell <enb> <cid> tanpa MCC/MNC
TG_DEFAULT_MCC=510
TG_DEFAULT_MNC=10

# Toggle bagian output (1/0, true/false)
TG_INCLUDE_LOCATION=1     # kirim Telegram Location native
TG_INCLUDE_ADDRESS=1      # tampilkan alamat
TG_INCLUDE_MAP_BUTTONS=1  # tombol Google/OSM/Bing/Waze/Apple
TG_INCLUDE_PLUS_CODE=1    # tampilkan Plus Code
TG_INCLUDE_AZIMUTH=1      # tampilkan estimasi arah pancar sektor

# =====================================================================
# Estimasi azimuth sektor (opsional)
# =====================================================================
# Mayoritas eNB LTE 3-sektor dengan antena 120° terpisah. Default
# mengasumsikan sektor 1=0° (Utara), 2=120°, 3=240°. Override global:
#
#   SECTOR_AZIMUTHS=30,150,270
#
# Atau per-operator pakai SECTOR_AZIMUTHS_<MCC>_<MNC> (MNC 2 digit):
#
#   SECTOR_AZIMUTHS_510_10=0,120,240   # Telkomsel
#   SECTOR_AZIMUTHS_510_11=30,150,270  # XL
#
# Nilai ini cuma estimasi karena setiap site di lapangan bisa di-tilt
# sesuai topografi. Tetap berguna sebagai panduan kasar.
#SECTOR_AZIMUTHS=0,120,240
